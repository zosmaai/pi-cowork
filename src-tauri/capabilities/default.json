{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Pi Cowork",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "notification:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": [
            "-c",
            { "validator": "\\S+" }
          ],
          "cmd": "sh",
          "name": "sh",
          "sidecar": false
        }
      ]
    }
  ]
}
